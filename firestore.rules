rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users: Can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Investments: Users create & read their own
    match /investments/{invId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false; // Prevent accidental deletion
    }
    
    // Transactions: Users read their own, system writes
    match /transactions/{txId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Notifications: Users read their own, system writes
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Only Cloud Functions should write
    }
  }
}